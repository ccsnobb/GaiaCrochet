       <div class="a11y-row"><span data-i18n="a11y.font">Font ad alta leggibilità</span><label class="switch"><input type="checkbox" data-pref="a11y-font"><span class="track"></span></label></div>
       <div class="a11y-row"><span data-i18n="a11y.large">Testo e immagini grandi</span><label class="switch"><input type="checkbox" data-pref="a11y-large"><span class="track"></span></label></div>
