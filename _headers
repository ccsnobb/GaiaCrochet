# Header HTTP per Cloudflare Pages.

# --- Sito pubblico: cookieless, nessuna risorsa esterna ---
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; connect-src 'self'; form-action mailto:; base-uri 'self'; frame-ancestors 'none'

# --- Font: cache lunga (file con nome stabile) ---
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# --- Pannello CMS: serve caricare Sveltia da CDN e parlare con GitHub ---
/admin/*
  X-Robots-Tag: noindex
  Content-Security-Policy: default-src 'self'; script-src 'self' https://unpkg.com 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; connect-src 'self' https://api.github.com https://raw.githubusercontent.com https://*.workers.dev https://unpkg.com https://www.githubstatus.com; font-src 'self' data: https://fonts.gstatic.com; frame-ancestors 'none'